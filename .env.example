# --- PostgreSQL -------------------------------------------------------------
POSTGRES_DB=tansu
POSTGRES_USER=tansu
POSTGRES_PASSWORD=tansu
POSTGRES_PORT=5432

# --- RabbitMQ ---------------------------------------------------------------
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- SMTP (MailHog в dev) ---------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@tansu.local
SMTP_USER=
SMTP_PASSWORD=
MAILHOG_UI_PORT=8025

# --- API --------------------------------------------------------------------
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

# Локальный JWT (субподрядчики). Не менее 32 символов.
JWT_ISSUER=tansu-api
JWT_AUDIENCE=tansu-clients
JWT_SIGNING_KEY=please-change-me-to-a-32+chars-secret-key

# Microsoft Entra ID
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_AUDIENCE=api://tansu

# --- Хранилище фото сотрудников --------------------------------------------
PHOTO_STORAGE_PATH=/var/lib/tansu/photos

# --- Frontend ---------------------------------------------------------------
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:8080
