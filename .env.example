# --- PostgreSQL -------------------------------------------------------------
POSTGRES_DB=tansu
POSTGRES_USER=tansu
POSTGRES_PASSWORD=tansu
POSTGRES_PORT=5432

# --- RabbitMQ ---------------------------------------------------------------
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- SMTP (MailHog в dev) ---------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@tansu.local
SMTP_USER=
SMTP_PASSWORD=
MAILHOG_UI_PORT=8025

# --- API --------------------------------------------------------------------
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

# Локальный JWT (субподрядчики). Не менее 32 символов.
JWT_ISSUER=tansu-api
JWT_AUDIENCE=tansu-clients
JWT_SIGNING_KEY=please-change-me-to-a-32+chars-secret-key

# Microsoft Entra ID (вход сотрудников ТАНСУ в API)
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_AUDIENCE=api://tansu

# Справочник ЗУП (api.tnsu.kz), client credentials — только на API, не в git
ZUP_BASE_URL=https://api.tnsu.kz
ZUP_TENANT_ID=
ZUP_CLIENT_ID=
ZUP_CLIENT_SECRET=
# Пусто = ENTRA_AUDIENCE + "/.default"
ZUP_AUDIENCE=
ZUP_SCOPE=

# --- Хранилище фото сотрудников --------------------------------------------
PHOTO_STORAGE_PATH=/var/lib/tansu/photos
# Лимит JPEG (байты). По умолчанию 1048576 (1 МБ).
EMPLOYEE_PHOTO_MAX_BYTES=1048576

# --- Брендинг (заголовок вкладки и UI) --------------------------------------
APP_BRAND_NAME=Tansu
APP_COMPANY_NAME=ТАНСУ

# --- Frontend ---------------------------------------------------------------
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:8080

# --- Личный кабинет сотрудника (отдельное приложение) ---------------------
EMPLOYEE_PORTAL_WEB_PORT=5175

# --- Verify (QR + Face ID) --------------------------------------------------
VERIFY_API_PORT=8091
VERIFY_WEB_PORT=5174
# Пусто = API через HTTPS proxy verify-web (нужно для камеры с телефона по LAN)
VITE_VERIFY_API_BASE_URL=
VITE_VERIFY_API_PROXY_TARGET=http://verify-api:8090
VERIFY_SERVICE_KEY=dev-verify-service-key-change-me
# Для теста с телефона укажите LAN IP: https://192.168.x.x:5174
AccessPass__VerifyWebBaseUrl=https://192.168.1.128:5174
AccessPass__VerifyServiceKey=dev-verify-service-key-change-me

# --- Face ID (Python + DeepFace, без Azure) ---------------------------------
FACE_VERIFY_PORT=8092
FACE_VERIFY_BASE_URL=http://face-verify:8092
FACE_VERIFY_TIMEOUT_SECONDS=120
FACE_VERIFY_MODEL=Facenet
FACE_VERIFY_DETECTOR=opencv
FACE_VERIFY_MAX_SIDE=1024

# --- Проверка фото сотрудников (Hikvision) -----------------------------------
# true = после автопроверки требуется ручное одобрение ТАНСУ
EMPLOYEE_PHOTO_REQUIRE_MANUAL=true

# --- Личный кабинет сотрудника ----------------------------------------------
EMPLOYEE_PORTAL_CREDENTIALS_PATH=/app/data/employee-portal-credentials.log
